      Design: Typography — SF Pro Text (Android: sans-serif / sans-serif-medium).
      Cặp số: size / line height; letterSpacing theo spec (≈ em).
    -->

    <!-- Headline — Bold -->
    <style name="TextAppearance.App.Headline.Large" parent="">
        <item name="android:textSize">40sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:letterSpacing">-0.012</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/body_primary</item>
    </style>

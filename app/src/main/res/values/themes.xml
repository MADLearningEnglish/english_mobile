<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (Light Mode) -->
    <style name="Base.Theme.Learning_english" parent="Theme.Material3.DayNight.NoActionBar">


        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Text colors -->
        <item name="colorOnBackground">@color/body_primary</item>
        <item name="colorOnSurface">@color/body_primary</item>
        <item name="android:textColor">@color/body_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error_color</item>

        <!-- Divider -->
        <item name="colorOutline">@color/divider</item>

    </style>

    <!-- Main theme used in Manifest -->
    <style name="Theme.Learning_english" parent="Base.Theme.Learning_english" />

    <!-- Circle shape appearance for ShapeableImageView -->
    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded rect for deck cover images -->
    <style name="RoundedCoverImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <!-- BottomSheet dialog rounded top corners -->
    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheetStyle</item>
    </style>

    <style name="AppBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/AppBottomSheetShapeAppearance</item>
        <item name="backgroundTint">@color/background</item>
    </style>

    <style name="AppBottomSheetShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Top-only rounded corners for the visual cue image on card back -->
    <style name="VisualCueTopRoundedStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
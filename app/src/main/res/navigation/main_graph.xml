<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_graph"
    app:startDestination="@+id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.mit.learning_english.presentation.feature.main.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main">

        <action
            android:id="@+id/action_mainFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
        <action
            android:id="@+id/action_mainFragment_to_searchBookFragment"
            app:destination="@id/searchBookFragment" />
        <action
            android:id="@+id/action_mainFragment_to_editDeckFragment"
            app:destination="@id/editDeckFragment" />
        <action
            android:id="@+id/action_mainFragment_to_studyFragment"
            app:destination="@id/studyFragment" />
        <action
            android:id="@+id/action_mainFragment_to_createDeckFragment"
            app:destination="@id/createDeckFragment" />
        <action
            android:id="@+id/action_mainFragment_to_bookByGenreFragment"
            app:destination="@id/bookByGenreFragment" />
        <action
            android:id="@+id/action_mainFragment_to_recommendBookFragment"
            app:destination="@id/recommendBookFragment" />
    </fragment>
    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.mit.learning_english.presentation.feature.bookdetail.BookDetailFragment"
        android:label="fragment_book_detail"
        tools:layout="@layout/fragment_book_detail">
        <argument
            android:name="bookId"
            app:argType="integer" />
        <action
            android:id="@+id/action_bookDetailFragment_to_readBookFragment"
            app:destination="@id/readBookFragment" />
    </fragment>
    <fragment
        android:id="@+id/readBookFragment"
        android:name="com.mit.learning_english.presentation.feature.readbook.ReadBookFragment"
        android:label="fragment_read_book"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        tools:layout="@layout/fragment_read_book">
        <argument
            android:name="readBookArgs"
            app:argType="com.mit.learning_english.presentation.feature.readbook.ReadBookArgs" />

    </fragment>
    <fragment
        android:id="@+id/searchBookFragment"
        android:name="com.mit.learning_english.presentation.feature.searchbook.SearchBookFragment"
        android:label="fragment_search_book"
        tools:layout="@layout/fragment_search_book">
        <action
            android:id="@+id/action_searchBookFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>


    <fragment
        android:id="@+id/editDeckFragment"
        android:name="com.mit.learning_english.presentation.feature.editdeck.EditDeckFragment"
        android:label="Chỉnh sửa bộ thẻ"
        tools:layout="@layout/fragment_edit_deck">
        <argument
            android:name="deckId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/createDeckFragment"
        android:name="com.mit.learning_english.presentation.feature.createdeck.CreateDeckFragment"
        android:label="Tạo bộ thẻ mới"
        tools:layout="@layout/fragment_create_deck" />

    <fragment
        android:id="@+id/studyFragment"
        android:name="com.mit.learning_english.presentation.feature.study.StudyFragment"
        android:label="Luyện tập"
        tools:layout="@layout/fragment_study">

        <argument
            android:name="deckId"
            android:defaultValue="0"
            app:argType="integer" />

        <argument
            android:name="deckTitle"
            android:defaultValue=""
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/bookByGenreFragment"
        android:name="com.mit.learning_english.presentation.feature.bookbygenre.BookByGenreFragment"
        android:label="fragment_book_by_genre"
        tools:layout="@layout/fragment_book_by_genre">

        <argument
            android:name="genreId"
            android:defaultValue="0"
            app:argType="integer" />

        <argument
            android:name="genreName"
            android:defaultValue=""
            app:argType="string" />

        <action
            android:id="@+id/action_bookByGenreFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/recommendBookFragment"
        android:name="com.mit.learning_english.presentation.feature.recommendbook.RecommendBookFragment"
        android:label="fragment_recommend_book"
        tools:layout="@layout/fragment_recommend_book">

        <action
            android:id="@+id/action_recommendBookFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/home"
        android:name="com.mit.learning_english.presentation.feature.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/chat"
        android:name="com.mit.learning_english.presentation.feature.chat.ChooseTopicFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_choose_topic">

        <action
            android:id="@+id/action_chooseTopic_to_aiChat"
            app:destination="@id/aiChatFragment" />
    </fragment>

    <fragment
        android:id="@+id/aiChatFragment"
        android:name="com.mit.learning_english.presentation.feature.ai.AiChatFragment"
        android:label="AI Chat"
        tools:layout="@layout/fragment_ai_chat">

        <argument
            android:name="sessionId"
            app:argType="integer" />

        <argument
            android:name="title"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="aiRole"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="levelName"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="instruction"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/profile"
        android:name="com.mit.learning_english.presentation.feature.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profile_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profile_to_profileVocabularyFragment"
            app:destination="@id/profileVocabularyFragment" />
        <action
            android:id="@+id/action_profile_to_profileDailyActivityFragment"
            app:destination="@id/profileDailyActivityFragment" />
        <action
            android:id="@+id/action_profile_to_profileActivityDayFragment"
            app:destination="@id/profileActivityDayFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.edit.EditProfileFragment"
        android:label="@string/edit_profile_title"
        tools:layout="@layout/fragment_profile_edit" />

    <fragment
        android:id="@+id/profileVocabularyFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.vocabulary.ProfileVocabularyFragment"
        android:label="@string/vocabulary_list_title"
        tools:layout="@layout/fragment_profile_vocabulary" />

    <fragment
        android:id="@+id/profileDailyActivityFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.daily.ProfileDailyActivityFragment"
        android:label="@string/daily_activity_title"
        tools:layout="@layout/fragment_profile_daily_activity" />

    <fragment
        android:id="@+id/profileActivityDayFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.day.ProfileActivityDayFragment"
        android:label="Activities"
        tools:layout="@layout/fragment_profile_activity_day">
        <argument
            android:name="isoDate"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/vocabulary"
        android:name="com.mit.learning_english.presentation.feature.decklist.DeckListFragment"
        android:label="Vocabulary"
        tools:layout="@layout/fragment_deck_list" />
</navigation>
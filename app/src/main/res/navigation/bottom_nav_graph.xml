<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_nav_graph"
    app:startDestination="@id/home">

    <fragment
        android:id="@+id/home"
        android:name="com.mit.learning_english.presentation.feature.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/chat"
        android:name="com.mit.learning_english.presentation.feature.ai.ChooseTopicFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_choose_topic">

        <action
            android:id="@+id/action_chooseTopic_to_aiChat"
            app:destination="@id/aiChatFragment" />
    </fragment>

    <fragment
        android:id="@+id/aiChatFragment"
        android:name="com.mit.learning_english.presentation.feature.ai.AiChatFragment"
        android:label="AI Chat"
        tools:layout="@layout/fragment_ai_chat">

        <argument
            android:name="sessionId"
            app:argType="integer" />

        <argument
            android:name="title"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="aiRole"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="levelName"
            android:defaultValue=""
            app:argType="string" />

        <argument
            android:name="instruction"
            android:defaultValue=""
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/profile"
        android:name="com.mit.learning_english.presentation.feature.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profile_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profile_to_profileVocabularyFragment"
            app:destination="@id/profileVocabularyFragment" />
        <action
            android:id="@+id/action_profile_to_profileDailyActivityFragment"
            app:destination="@id/profileDailyActivityFragment" />
        <action
            android:id="@+id/action_profile_to_profileActivityDayFragment"
            app:destination="@id/profileActivityDayFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.edit.EditProfileFragment"
        android:label="@string/edit_profile_title"
        tools:layout="@layout/fragment_profile_edit" />

    <fragment
        android:id="@+id/profileVocabularyFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.vocabulary.ProfileVocabularyFragment"
        android:label="@string/vocabulary_list_title"
        tools:layout="@layout/fragment_profile_vocabulary" />

    <fragment
        android:id="@+id/profileDailyActivityFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.daily.ProfileDailyActivityFragment"
        android:label="@string/daily_activity_title"
        tools:layout="@layout/fragment_profile_daily_activity" />

    <fragment
        android:id="@+id/profileActivityDayFragment"
        android:name="com.mit.learning_english.presentation.feature.profile.day.ProfileActivityDayFragment"
        android:label="Activities"
        tools:layout="@layout/fragment_profile_activity_day">
        <argument
            android:name="isoDate"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/vocabulary"
        android:name="com.mit.learning_english.presentation.feature.decklist.DeckListFragment"
        android:label="Vocabulary"
        tools:layout="@layout/fragment_deck_list" />

</navigation>

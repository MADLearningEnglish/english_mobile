<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded card with all input fields -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/border_16"
    android:elevation="3dp"
    android:orientation="vertical">

    <!-- Card header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F007AFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvCardIndex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            tools:text="THẺ #1" />

        <ImageButton
            android:id="@+id/btnDeleteCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Xoá thẻ"
            android:src="@drawable/ic_delete"
            app:tint="@color/gray_400" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Form fields -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Word + Phonetic row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Word input (2/3 width) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginBottom="4dp"
                    android:text="Từ tiếng Anh"
                    android:textColor="@color/gray_400"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etWord"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/border_16"
                    android:hint="e.g. Ephemeral"
                    android:inputType="text"
                    android:padding="10dp"
                    android:textColor="@color/body_primary"
                    android:textColorHint="@color/gray_400"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Phonetic input (1/3 width) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginBottom="4dp"
                    android:text="Phiên âm"
                    android:textColor="@color/gray_400"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etPhonetic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/border_16"
                    android:fontFamily="monospace"
                    android:hint="/.../  "
                    android:inputType="text"
                    android:padding="10dp"
                    android:textColor="@color/gray_400"
                    android:textColorHint="@color/body_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Meaning input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="4dp"
                android:text="Nghĩa tiếng Việt"
                android:textColor="@color/gray_400"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etMeaning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/border_16"
                android:hint="Nhập nghĩa của từ..."
                android:inputType="text"
                android:padding="10dp"
                android:textColor="@color/body_primary"
                android:textColorHint="@color/gray_400"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Example sentence input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="4dp"
                android:text="Câu ví dụ"
                android:textColor="@color/gray_400"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/etExample"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/border_16"
                android:gravity="top"
                android:hint="Viết một câu ví dụ..."
                android:inputType="textMultiLine"
                android:lines="2"
                android:padding="10dp"
                android:textColor="@color/body_primary"
                android:textColorHint="@color/gray_400"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Visual Cue Image Uploader -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="4dp"
                android:text="Ảnh minh họa"
                android:textColor="@color/gray_400"
                android:textSize="11sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnUploadVisualCue"
                android:layout_width="120dp"
                android:layout_height="90dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgVisualCuePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/layoutUploadPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_add"
                        app:tint="@color/gray_400" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thêm ảnh"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/gray_400" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_screen_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIconTint="@color/ai_title_navy"
        app:title="@string/ai_choose_topic_title"
        app:titleCentered="true"
        app:titleTextAppearance="@style/TextAppearance.ChooseTopic.ToolbarTitle"
        app:titleTextColor="@color/ai_title_navy" />

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/ai_toolbar_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:boxBackgroundColor="@color/white"
        app:boxCornerRadiusBottomEnd="24dp"
        app:boxCornerRadiusBottomStart="24dp"
        app:boxCornerRadiusTopEnd="24dp"
        app:boxCornerRadiusTopStart="24dp"
        app:boxStrokeColor="@color/ai_search_box_stroke"
        app:boxStrokeWidth="1dp"
        app:hintEnabled="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider"
        app:startIconMinSize="22dp"
        app:startIconTint="@color/ai_hint_on_light">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ai_search_scenarios"
            android:inputType="text"
            android:maxLines="1"
            android:paddingVertical="16dp"
            android:paddingHorizontal="8dp"
            android:textColor="@color/ai_text_on_light"
            android:textColorHint="@color/ai_hint_on_light"
            style="@style/BodyMedium" />
    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:id="@+id/chipScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchLayout">

        <LinearLayout
            android:id="@+id/chipRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_ai_filter_selected"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/ai_filter_all"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterBeginner"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_ai_filter_unselected"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/ai_filter_beginner"
                android:textColor="@color/ai_chip_text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/filterIntermediate"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_ai_filter_unselected"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/ai_filter_intermediate"
                android:textColor="@color/ai_chip_text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/filterAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_ai_filter_unselected"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/ai_filter_advanced"
                android:textColor="@color/ai_chip_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/planRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipScroll">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoal"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textAllCaps="false"
            android:text="Goal: Communication" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMode"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textAllCaps="false"
            android:text="Mode: Coach" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/listContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnFreeTalk"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/planRow">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerScenarios"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            tools:listitem="@layout/item_scenario_card" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="@string/ai_scenarios_empty"
            android:textColor="@color/ai_hint_on_light"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFreeTalk"
        style="@style/Widget.Material3.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:minHeight="52dp"
        android:paddingHorizontal="28dp"
        android:paddingVertical="12dp"
        android:text="@string/ai_free_talk"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="26dp"
        app:icon="@drawable/ic_chat"
        app:iconGravity="end"
        app:iconPadding="10dp"
        app:iconSize="22dp"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="118dp"
    android:paddingVertical="8dp"
    android:background="@drawable/border_16"
    android:backgroundTint="@color/surface"
    android:paddingHorizontal="12dp">


    <androidx.cardview.widget.CardView
        android:id="@+id/cardCoverBook"
        android:layout_width="68dp"
        android:layout_height="0dp"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="H,1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBookCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="7"
        app:layout_constraintStart_toEndOf="@id/cardCoverBook"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBookTitle"
            style="@style/LabelSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            tools:text="Suy Tưởng (Meditations)"
            android:textColor="@color/body_primary" />

        <TextView
            android:id="@+id/tvBookAuthor"
            style="@style/BodyExtraSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="Marcus Aurelius" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/pbProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressDrawable="@drawable/progress_bg" />

            <TextView
                android:id="@+id/tvProgressPercent"
                style="@style/BodyExtraSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/body_secondary"
                tools:text="80%" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLastReadTime"
            style="@style/BodyExtraSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/body_secondary"
            tools:text="Last read: 08/04/2026 14:30" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<!-- Success dialog shown after deck is created -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Confetti / Decorative header area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_header_gradient">

        <!-- Star 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="28dp"
            android:layout_marginTop="28dp"
            android:text="@string/deck_success_star_1"
            android:textSize="20sp"
            tools:ignore="HardcodedText" />

        <!-- Star 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginEnd="50dp"
            android:layout_marginTop="36dp"
            android:text="@string/deck_success_star_2"
            android:textSize="16sp"
            tools:ignore="HardcodedText" />

        <!-- Star 3 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="60dp"
            android:layout_marginBottom="30dp"
            android:text="@string/deck_success_star_3"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

        <!-- Owl mascot -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="@string/deck_success_mascot"
            android:textSize="72sp"
            tools:ignore="HardcodedText" />
    </FrameLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/deck_success_title"
            android:textColor="@color/body_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvDialogMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/deck_success_message"
            android:textColor="@color/gray_400"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnStartStudy"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/primary"
            android:text="@string/deck_success_start_now"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGoToList"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/deck_success_back_to_list"
            android:textColor="@color/body_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

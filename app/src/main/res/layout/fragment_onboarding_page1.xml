<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:padding="24dp">

    <!-- Illustration Container -->
    <FrameLayout
        android:id="@+id/illustrationContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvTitle"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Background Decorative Blobs (Vector or Shape) -->
        <View
            android:layout_width="200dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            android:rotation="-2"
            android:background="@drawable/bg_blob_soft"
            android:alpha="0.5"/>

        <!-- Main Flashcard Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:rotation="5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_word"
                    style="@style/LabelExtraSmall"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:background="@color/surface_variant"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="Eloquent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    style="@style/LabelMedium"
                    android:textColor="@color/primary"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="/ˈel.ə.kwənt/"
                    android:textSize="14sp"
                    android:textColor="@color/body_primary"
                    android:gravity="center"/>
            </LinearLayout>
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/border_12"
                android:padding="4dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:layout_gravity="top|end"
                app:tint="@color/primary"
                android:src="@drawable/ic_volumn"
                />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="@string/master_vocabulary_with_flashcards"
        android:textColor="@color/primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tvDescription"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/illustrationContainer" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/personalized_flashcards_help_you_memorize_new_words_and_phrases_efficiently_through_repetition"
        android:textSize="16sp"
        android:textColor="@color/body_primary"
        android:gravity="center"
        style="@style/LabelExtraSmall"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:padding="24dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_headphone"
        android:layout_marginTop="120dp"
        android:elevation="32dp"
        android:layout_marginEnd="64dp"
        app:layout_constraintEnd_toEndOf="@+id/illustrationContainer"
        app:layout_constraintTop_toTopOf="@+id/illustrationContainer"
        app:tint="@color/primary" />

    <FrameLayout
        android:id="@+id/illustrationContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/tvTitle"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Audio Player Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="280dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivBook"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_reading_book"
                    app:tint="@color/primary" />

                <View
                    android:layout_width="120dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivBook"
                    android:background="@color/surface_variant" />

                <View
                    android:layout_width="80dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_toEndOf="@id/ivBook"
                    android:background="@color/surface_variant" />

                <View
                    android:layout_width="92dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="32dp"
                    android:layout_toEndOf="@id/ivBook"
                    android:background="@color/surface_variant" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/surface_variant"
                    android:padding="16dp"
                    android:src="@drawable/ic_play"
                    app:tint="#0058BB" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Translation Chip Overlay -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:rotation="8"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:rotation="8"
                    android:src="@drawable/ic_translation"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:rotation="3"
                    android:text="@string/onboarding_translation_sample"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/audiobook_and_n_translate"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="center"
        style="@style/HeadlineSmall"
        app:layout_constraintTop_toBottomOf="@id/illustrationContainer"
        app:layout_constraintBottom_toTopOf="@+id/tvDescription"/>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/enjoy_english_audiobooks_with_instant_word_translation_and_pronunciation_for_every_sentence"
        style="@style/LabelMedium"
        android:textColor="@color/body_primary"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
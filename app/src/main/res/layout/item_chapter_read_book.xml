<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/border_24_stroke"
    android:backgroundTint="@color/surface_gray"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp">


    <TextView
        android:id="@+id/tvNumber"
        style="@style/HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01"
        android:textColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvChapterTitle"
        style="@style/HeadlineExtraSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="The Library of Choices"
        android:textColor="@color/body_primary"
        app:layout_constraintBottom_toTopOf="@+id/tvTotalPages"
        app:layout_constraintStart_toEndOf="@+id/tvNumber"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvTotalPages"
        style="@style/BodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="123 pages"
        android:textColor="@color/body_gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvChapterTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvChapterTitle" />

    <View
        android:id="@+id/icDot"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/body_gray"
        app:layout_constraintBottom_toBottomOf="@+id/tvTotalPages"
        app:layout_constraintStart_toEndOf="@+id/tvTotalPages"
        app:layout_constraintTop_toTopOf="@+id/tvTotalPages" />

    <TextView
        android:id="@+id/tvDurations"
        style="@style/BodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="12:45 minus"
        android:textColor="@color/body_gray"
        app:layout_constraintBottom_toBottomOf="@id/tvTotalPages"
        app:layout_constraintStart_toEndOf="@id/icDot"
        app:layout_constraintTop_toTopOf="@id/tvTotalPages" />


</androidx.constraintlayout.widget.ConstraintLayout>